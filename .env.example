# Twilio credentials: https://console.twilio.com/
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# The ONE caller ID you will submit in E.164 format. Buy/use a Twilio Voice number.
TWILIO_FROM_NUMBER=+13334445555

# Your public HTTPS base URL from ngrok or Cloudflare Tunnel, no trailing slash.
# Example: https://abc123.ngrok-free.app
PUBLIC_BASE_URL=https://your-public-url.ngrok-free.app

# OpenAI is used to make the patient simulator adapt to the AI agent and to analyze bugs.
# If omitted, the bot falls back to deterministic scripted responses, but LLM mode is stronger.
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_MODEL=gpt-4o-mini

# Safety guardrails. Do not change the assessment number.
ASSESSMENT_NUMBER=+18054398008
MAX_TURNS_PER_CALL=8
TWILIO_VOICE=Polly.Joanna-Neural
SPEECH_GATHER_TIMEOUT_SECONDS=8
